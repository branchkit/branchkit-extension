{
  "manifest_version": 3,
  "name": "BranchKit Browser",
  "version": "0.1.0",
  "description": "Voice-navigable hint badges for any website. Works standalone or with BranchKit.",
  "permissions": ["offscreen", "tabs", "activeTab", "storage", "alarms"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

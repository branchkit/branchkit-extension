node_modules/
dist/
*.zip
.DS_Store

# Chrome extension build outputs and signing key. The .crx is a packed
# extension archive (rebuilt from `dist/` on every package step); the
# .pem is the private signing key that authenticates extension updates
# — *never* commit it. If it leaks, anyone holding the key can publish
# updates that browsers will auto-install as this extension.
dist.crx
dist.pem
*.crx
*.pem
test-fixtures/output/

# Local dev / repro scripts. The leading-underscore convention (`_test-*`,
# `_drive-*`, `_snapshot.mjs`, `_verify-*`, `_watch-*`) marks files that
# are dated ad-hoc repros for specific bugs/incidents — they reference
# user reports by date and aren't part of the test suite. Keep them out
# of the repo so `git status` stays meaningful when working in scripts/.
scripts/_*

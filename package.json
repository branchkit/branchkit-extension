{
  "name": "branchkit-browser",
  "version": "0.1.0",
  "description": "BranchKit Browser — voice-navigable hint badges",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "dev": "node scripts/dev.mjs chrome",
    "dev:firefox": "node scripts/dev.mjs firefox",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:firefox": "npm run build:firefox && npx --yes web-ext lint --source-dir=dist/firefox",
    "package:firefox": "npm run build:firefox && npx --yes web-ext build --source-dir=dist/firefox --artifacts-dir=artifacts --overwrite-dest",
    "test:placement": "npm run build:chrome && node scripts/test-placement.mjs",
    "test:perf": "npm run build:chrome && node scripts/test-perf.mjs",
    "test:scroll-accel": "npm run build:chrome && node scripts/test-scroll-accel.mjs",
    "test:scroll-accel-nested": "npm run build:chrome && node scripts/test-scroll-accel-nested.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "esbuild": "^0.27.2",
    "happy-dom": "^20.9.0",
    "playwright": "^1.60.0",
    "playwright-webextext": "^0.0.5",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5",
    "ws": "^8.20.1"
  },
  "dependencies": {
    "apca-w3": "^0.1.9"
  }
}
